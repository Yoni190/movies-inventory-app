<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

</head>
<body>
    <h1><%= title %></h1>
    <table class="border">
        <thead>
            <tr>
                <th class="text-center">Title</th>
                <th class="text-center">Rating</th>
                <th class="text-center">Directors</th>
                <th class="text-center">Genre</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
            <% movies.forEach((movie) => { %>
                <tr>
                    <td><%= movie.title %></td>
                    <td><%= movie.rating %></td>
                    <td>
                        <% movie.directors.forEach((director) => { %>
                            <%= director.f_name %> <%= director.l_name %>
                        <% }) %>
                    </td>
                    <td>
                        <% movie.categories.forEach((category) => { %>
                            <%= category.name%>
                        <% }) %>
                    </td>

                    <td>
                        <a href="/<%= movie.id %>/edit">Edit movie</a>

                        <form action="/<%= movie.id %>/delete" method="POST">
                            <button>Delete Movie</button>
                        </form>
                    </td>

                </tr>
                
            <% }) %>
        </tbody>
        
    </table>

    <div>
        <a href="/create">Create Movies</a>
        <a href="/directors/create">Create Directors</a>
        <a href="/categories/create">Create Categories</a>
    </div>

    <div>
        <a href="/directors">Directors</a>
        <a href="/categories">Categories</a>
    </div>
</body>
</html>