<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body>
    <h1><%= title %></h1>
    <% movies.forEach((movie) => { %>
        <p><%= movie.title %></p>
        <p><%= movie.rating %></p>
        <% movie.director.forEach((director) => { %>
            <p><%= director %></p>
       <% }) %>
    <% }) %>
</body>
</html>